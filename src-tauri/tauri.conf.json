{
  "productName": "sup",
  "version": "0.1.0",
  "identifier": "com.onur.sup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "https://web.whatsapp.com",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "sup",
        "fullscreen": false,
        "resizable": true,
        "width": 1200,
        "height": 800,
        "url": "https://web.whatsapp.com"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
